# ─────────────────────────────────────────────────────────────────────────────
# .env — Dirigera MQTT Bridge configuration
#
# Copy this file to .env and fill in the values for your environment.
# This file is loaded at startup by app/config.py via python-dotenv.
#
# SECURITY:
#   - This file contains secrets (DIRIGERA_TOKEN, MQTT_PASSWORD).
#   - Never commit this file to version control.
#   - Add .env to .gitignore.
#   - This file is NOT copied into the Docker image — it is mounted
#     at runtime via the env_file directive in docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────


# ── Dirigera hub ──────────────────────────────────────────────────────────────

# IP address of the Dirigera hub on your local network
DIRIGERA_IP=

# Access token for the Dirigera WebSocket and REST API.
# Obtain this via the Dirigera pairing flow (see README.md).
# Treat this like a password — keep it secret.
DIRIGERA_TOKEN=

# Dirigera access port (default: 8443)
DIRIGERA_PORT=8443


# ── MQTT broker ───────────────────────────────────────────────────────────────

# Hostname of the MQTT broker.
# Use the Docker container name when running on the same Docker network.
MQTT_HOST=

# MQTT broker port (default: 1883 for unencrypted)
MQTT_PORT=1883

# MQTT broker credentials
# Leave empty if the broker allows anonymous connections (development only).
MQTT_USER=
MQTT_PASSWORD=

# MQTT client identifier sent to the broker on connect.
# Used for broker-side log filtering and session identification.
# Must be unique per client on the broker.
MQTT_CLIENT_ID=

# MQTT keepalive interval in seconds.
# How often the client sends a PINGREQ to keep the connection alive.
# Must be greater than WS_PING_TIMEOUT.
MQTT_KEEPALIVE=60

# Base topic prefix for all state and command topics owned by this bridge.
# Example: dirigera/light/abc123/state
# Distinct from DISCOVERY_PREFIX which is controlled by Home Assistant.
MQTT_BASE_TOPIC=dirigera

# MQTT Quality of Service level for all publishes and subscriptions.
# 0 = at most once, 1 = at least once, 2 = exactly once
# Recommended: 1 (at least once) for reliable state delivery
MQTT_QOS=1


# ── Home Assistant ────────────────────────────────────────────────────────────

# MQTT discovery topic prefix.
# Must match the discovery prefix configured in Home Assistant.
# Default in HA is 'homeassistant' — only change if you changed HA's setting.
DISCOVERY_PREFIX=homeassistant


# ── Operational (optional — defaults shown) ───────────────────────────────────

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO for production
LOG_LEVEL=INFO

# Seconds between periodic metrics log snapshots (minimum: 10)
METRICS_INTERVAL=300

# WebSocket keepalive ping interval in seconds (minimum: 5)
WS_PING_INTERVAL=30

# Seconds to wait for a WebSocket pong before declaring connection dead.
# Must be less than WS_PING_INTERVAL.
WS_PING_TIMEOUT=10

# Initial reconnect delay in seconds for exponential backoff (minimum: 0.1)
RECONNECT_DELAY_INITIAL=1.0

# Maximum reconnect delay cap in seconds.
# Must be >= RECONNECT_DELAY_INITIAL.
RECONNECT_DELAY_MAX=60.0
