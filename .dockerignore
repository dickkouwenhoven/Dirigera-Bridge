# .dockerignore

# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/

# Virtual environments
.venv
venv
env

# Test and coverage artifacts
.pytest_cache
.coverage
coverage.xml
htmlcov/

# Type checker cache
.mypy_cache

# IDE and editor files
.vscode
.idea
*.swp
*.swo

# Docker files (no need to copy into image)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation
docs/

# Examples (not needed for tests)
examples/

# OS files
.DS_Store
Thumbs.db

# Secrets — never copy these
*.key
*.crt
*.pem
mosquitto/passwd
